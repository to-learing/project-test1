.page-container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f5f5;
}

.avatar-wrap {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
}

.btn-follow {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  background: #000;
  color: #fff;
}

.btn-follow.followed {
  background: #f5f5f5;
  color: #999;
  border: 1rpx solid #ddd;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.no-more-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #ccc;
  font-size: 24rpx;
}