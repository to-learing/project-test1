.page-container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* 话题列表 */
.topic-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.topic-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.topic-content {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.topic-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.topic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.topic-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.topic-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.topic-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.topic-date {
  margin-left: auto;
}

/* 操作区域 */
.topic-actions {
  display: flex;
  justify-content: flex-end;
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}

/* 空状态 */
.empty-container {
  padding: 100rpx 0;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.loading-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}