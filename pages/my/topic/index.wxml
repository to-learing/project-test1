<view class="page-container">
  <!-- 话题列表 -->
  <view class="topic-list" wx:if="{{topics.length > 0}}">
    <view class="topic-item" wx:for="{{topics}}" wx:key="id">
      <view class="topic-content" bindtap="goToDetail" data-id="{{item.id}}">
        <!-- 封面图 -->
        <image 
          wx:if="{{item.coverImage}}" 
          class="topic-cover" 
          src="{{item.coverImage}}" 
          mode="aspectFill"
        />
        <view class="topic-info">
          <view class="topic-title">{{item.title}}</view>
          <view class="topic-desc" wx:if="{{item.content}}">{{item.content}}</view>
          <view class="topic-meta">
            <view class="meta-item">
              <t-icon name="browse" size="28rpx" />
              <text>{{item.viewCount}}</text>
            </view>
            <view class="meta-item">
              <t-icon name="heart" size="28rpx" />
              <text>{{item.likeCount}}</text>
            </view>
            <view class="meta-item">
              <t-icon name="chat" size="28rpx" />
              <text>{{item.commentCount}}</text>
            </view>
            <text class="topic-date">{{item.date}}</text>
          </view>
        </view>
      </view>
      <!-- 删除按钮 -->
      <view class="topic-actions">
        <t-button 
          theme="danger" 
          variant="text" 
          size="small"
          icon="delete"
          bindtap="deleteTopic" 
          data-id="{{item.id}}"
          data-title="{{item.title}}"
        >删除</t-button>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{isEmpty && !loading}}">
    <t-empty icon="info-circle-filled" description="暂无话题">
      <t-button 
        slot="action" 
        theme="primary" 
        size="small"
        bindtap="goToCreate"
      >去发布</t-button>
    </t-empty>
  </view>
  
  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>
  
  <!-- 没有更多了 -->
  <view class="no-more" wx:if="{{!hasMore && topics.length > 0 && !loading}}">
    <text>—— 没有更多了 ——</text>
  </view>
</view>