/** 自定义页面背景 */
.custom-page {
  background-color: var(--bg-color-page);
  height: 100vh;
}

/* 顶部区域 */
.user-header {
  position: relative;
  background: linear-gradient(180deg, var(--brand-color) 0%, var(--brand-color) 80%, #f5f7fa 100%);
  padding: 0 40rpx 60rpx; /* 减少底部留白 */
  color: #fff;
  /* 移除大圆角，改为直角过渡或者微调整，因为使用了渐变过渡到白色背景 */
  overflow: visible;
  z-index: 1;
}

.user-header::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 85%;
  background: linear-gradient(135deg, var(--brand-color) 0%, var(--brand-color) 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  z-index: -1;
}

.user-info-box {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  margin-top: 100rpx;
  position: relative;
  z-index: 2;
  padding: 0 10rpx;
}

.avatar-box {
  margin-right: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  margin-right: 16rpx;
  color: #fff;
  letter-spacing: 1rpx;
}

.member-tag {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  line-height: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.member-tag text {
  margin-left: 6rpx;
  font-weight: 500;
}

.bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  max-width: 450rpx;
}

.setting-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(5px);
}

/* 数据统计栏 */
.status-row {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  position: relative;
  z-index: 2;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  margin: 0 10rpx;
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0;
  flex: 1; /* 均分 */
}

/* 竖线分割 */
.status-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 30rpx;
  background: rgba(255, 255, 255, 0.2);
}

.status-item:active {
  opacity: 0.8;
  background: transparent;
}

.status-item .num {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #fff;
  font-family:
    -apple-system,
    BlinkMacSystemFont,
    "Helvetica Neue",
    Helvetica,
    Segoe UI,
    Arial,
    Roboto,
    "PingFang SC",
    "miui",
    "Hiragino Sans GB",
    "Microsoft Yahei",
    sans-serif;
}

.status-item .label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 会员卡片 - 悬浮效果 */
.member-card-wrapper {
  padding: 0 32rpx;
  margin-top: 20rpx; /* 不需要负margin了，因为 header 下部已经留空 */
  position: relative;
  z-index: 10;
  margin-bottom: 30rpx;
}

.member-card {
  background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);
  border-radius: 24rpx;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.2);
  color: #ffe4ba;
  position: relative;
  overflow: hidden;
}

.member-card::after {
  content: "";
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(
    circle,
    rgba(247, 217, 170, 0.1),
    transparent 70%
  );
  border-radius: 50%;
}

.card-left {
  display: flex;
  align-items: center;
}

.card-text {
  display: flex;
  flex-direction: column;
  margin-left: 24rpx;
}

.card-text .title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
  color: #ffe4ba;
}

.card-text .desc {
  font-size: 24rpx;
  color: rgba(255, 228, 186, 0.6);
}

.card-btn {
  background: linear-gradient(90deg, #ffe4ba 0%, #e3be82 100%);
  color: #333;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 34rpx;
  box-shadow: 0 4rpx 12rpx rgba(227, 190, 130, 0.3);
}

/* 列表菜单 */
.menu-list {
  padding: 0 24rpx;
}
