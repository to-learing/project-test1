.page-container {
  min-height: 100vh;
  background-color: var(--bg-color-page);
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 0;
  margin-bottom: 40rpx;
}

.avatar-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}

.avatar-cell .tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.input-box {
  padding: 0 20rpx;
}

.btn-area {
  margin-top: 60rpx;
}