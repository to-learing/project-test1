/**
 * 文章详情页样式
 * 重新设计版本
 */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-color-container, #fff);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========================================
   文章标题区域
   ======================================== */
.article-title-section {
  padding: 32rpx 32rpx 24rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color-primary, #333);
  line-height: 1.5;
}

/* ========================================
   作者信息区域
   ======================================== */
.author-section {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 20rpx;
}

.current-user-avatar {
  --td-avatar-bg-color: #ffffff;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color-primary, #333);
}

/* ========================================
   文章内容
   ======================================== */
.article-content {
  padding: 24rpx 32rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-color-primary, #333);
}

.article-content rich-text {
  display: block;
}

/* ========================================
   文章内容截断容器与蒙层
   ======================================== */
.article-content-wrapper {
  position: relative;
}

.article-content-wrapper.is-truncated {
  padding-bottom: 0;
}

.member-lock-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  /* 增加高度以获得更平滑的渐变 */
  background: linear-gradient(to bottom,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.9) 40%,
      rgba(255, 255, 255, 1) 100%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 48rpx;
  z-index: 10;
}

.lock-container {
  width: 90%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.lock-header {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lock-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color-primary, #333);
}

.lock-subtitle {
  font-size: 26rpx;
  color: var(--text-color-secondary, #999);
}

.unlock-btn {
  width: 100%;
  height: 88rpx;
  background: var(--black-color, #000000);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s;
}

.unlock-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 8rpx rgba(0, 203, 204, 0.2);
}

/* ========================================
   会员提示 (Old - Removed in new design but keeping class for safety if reused)
   ======================================== */
.member-tip {
  position: relative;
  padding: 48rpx 32rpx;
  margin: 0 32rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.9), #fffbe6);
  border-radius: 16rpx;
  text-align: center;
}

.tip-overlay {
  position: absolute;
  top: -100rpx;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to bottom,
      rgba(255, 255, 255, 0),
      rgba(255, 255, 255, 1));
}

.tip-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  margin-bottom: 16rpx;
}

.tip-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-color-primary, #333);
}

.tip-desc {
  font-size: 28rpx;
  color: var(--text-color-secondary, #666);
  margin-bottom: 16rpx;
}

/* ========================================
   编辑时间
   ======================================== */
.edit-time-section {
  padding: 16rpx 32rpx 32rpx;
}

.edit-time {
  font-size: 26rpx;
  color: var(--text-color-placeholder, #bbb);
}

/* ========================================
   底部操作栏
   ======================================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  justify-content: space-between;
  align-items: center;
  padding: 0rpx 20rpx 32rpx;
  background-color: var(--bg-color-container, #fff);
  border-top: 1rpx solid var(--component-border, #eee);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  color: var(--text-color-secondary, #666);
}

.action-btn::after {
  border: none;
}

.action-btn.liked {
  color: var(--danger-color, #ff4757);
}

.action-btn.favorited {
  color: var(--brand-color, #00b3b3);
}

.share-btn {
  background: none !important;
}

.bottom-bar-input-wrapper {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
}

.bottom-bar-input-wrapper-inner {
  flex: 1;
  background-color: var(--gray-color-1, #ffffff);
  border-radius: 40rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.bottom-bar-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  margin-left: 12rpx;
}
