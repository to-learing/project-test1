/**
 * 文章列表页样式
 */

.page-container {
  min-height: 100vh;
  background: var(--bg-white-linear-gradient);
}

/* ==================== 页面头部 ==================== */
.page-header {
  padding: 5vh 32rpx 60rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -30rpx;
  height: 60rpx;
  background: #f5f6f8;
  border-radius: 30rpx 30rpx 0 0;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 搜索栏 ==================== */
.search-bar {
  padding: 0 16rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

/* ==================== 骨架屏加载 ==================== */
.loading-wrapper {
  padding: 24rpx;
}

.skeleton-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-title {
  height: 40rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  width: 80%;
}

.skeleton-desc {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  width: 60%;
}

.skeleton-meta {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  width: 40%;
}

.skeleton-cover {
  width: 180rpx;
  height: 130rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ==================== 文章列表 ==================== */
.article-list {
  padding: 16rpx 24rpx 40rpx;
}

.article-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s, box-shadow 0.2s;
}

.article-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* ==================== 有封面图布局 ==================== */
.article-with-cover {
  display: flex;
  gap: 24rpx;
}

.article-with-cover .article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 140rpx;
}

.article-with-cover .article-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.article-with-cover .article-cover image {
  width: 100%;
  height: 100%;
}

/* ==================== 无封面图布局 ==================== */
.article-no-cover {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ==================== 文章标题 ==================== */
.article-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 文章元信息 ==================== */
.article-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-time {
  margin-left: auto;
}

/* ==================== 加载更多 ==================== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

/* ==================== 没有更多 ==================== */
.no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #bbb;
  font-size: 26rpx;
}

/* ==================== 空状态 ==================== */
.empty-wrapper {
  padding-top: 100rpx;
}
