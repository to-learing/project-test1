/**
 * 首页样式 - Refined Blue Theme
 * 风格：精致、通透、年轻化
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: env(safe-area-inset-top) 0rpx 0rpx;
  background-color: #F2F4F7; /* 更有质感的灰调背景 */
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* 顶部大背景 - 营造空间感 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 600rpx;
  background: linear-gradient(180deg, var(--teal-color-1, #e6f7f5) 0%, rgba(242, 244, 247, 0) 100%);
  z-index: 0;
}

/* 内容区域 */
.content-wrapper {
  position: relative;
  z-index: 10;
  padding: calc(env(safe-area-inset-top) + 24px) 32rpx 40rpx;
}

/* Header 设计优化 */
.header {
  margin-bottom: 48rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.app-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #000000;
  line-height: 1;
  letter-spacing: 2rpx;
}

.app-tag {
  background: #000;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #666;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* Section Title */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 24rpx;
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 
 * Hero Card (Dashboard) 
 * 采用微光质感的蓝色背景
 */
.hero-card {
  background: var(--brand-gradient-hero, linear-gradient(120deg, #00b3b3 0%, #1d857b 100%));
  border-radius: 36rpx;
  padding: 48rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 179, 179, 0.25); /* 青绿色彩色投影 */
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* 装饰性光斑 */
.hero-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2), transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  padding: 8rpx 20rpx;
  border-radius: 200rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 32rpx;
  letter-spacing: 1rpx;
}

.hero-card-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-card-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  max-width: 60%;
}

.hero-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  position: absolute;
  bottom: 48rpx;
  right: 48rpx;
  backdrop-filter: blur(5px);
}

.hero-btn text {
  display: none; /* 隐藏文字，只留纯净的箭头 */
}

/* 装饰大图 */
.hero-visual {
  display: none; /* 极简风格可以不需要背景大图标，显得更清爽 */
}

/* 
 * Module List
 * 采用通透的卡片风格
 */
.module-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.module-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  /* 极轻微的阴影，让卡片有立体感但不过重 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

/* 图标容器 - 左侧大色块 */
.module-card-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

/* 文字内容 */
.module-card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.module-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* 那个颜色小条 */
.module-card::after {
  content: '';
  position: absolute;
  left: 0;
  top: 32rpx;
  bottom: 32rpx;
  width: 8rpx;
  background: transparent;
  border-radius: 0 8rpx 8rpx 0;
}

/* 选中态/Hover态 */
.card-hover {
  transform: scale(0.99);
  background: #fafafa;
}

.module-action {
  display: none;
}

/* Hero卡片点击态 - 仅缩放，不改变背景色 */
.hero-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

