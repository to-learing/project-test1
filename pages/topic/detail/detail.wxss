.detail-container {
  min-height: 100vh;
  background-color: var(--bg-color-container, #fff);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.topic-main-wrapper {
  padding: 32rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 32rpx;
  line-height: 1.3;
}

.user-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.author-info {
  display: flex;
  align-items: center;
}

.author-meta {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.topic-footer {
  margin-top: 24rpx;
}

.publish-time {
  font-size: 26rpx;
  color: #999;
}

.follow-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand-color, #00b3b3);
  border: 1rpx solid var(--brand-color, #00b3b3);
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
}

.follow-btn.followed {
  color: #999;
  border-color: #ddd;
  background-color: #f5f5f5;
}

.content {
  margin-bottom: 32rpx;
}

.text-content {
  font-size: 32rpx;
  line-height: 1.7;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-img {
  border-radius: 12rpx;
  display: block;
}

.tags-section {
  margin-bottom: 24rpx;
  display: flex;
  flex-wrap: wrap;
}

.tag-pill {
  font-size: 28rpx;
  color: var(--brand-color, #00b3b3);
  margin-right: 20rpx;
  margin-bottom: 12rpx;
}

.divider-line {
  height: 16rpx;
  background-color: #f6f6f6;
  margin-bottom: 24rpx;
}

/* ========================================
   底部操作栏
   ======================================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  justify-content: space-between;
  align-items: center;
  padding: 0rpx 20rpx 32rpx;
  background-color: var(--bg-color-container, #fff);
  border-top: 1rpx solid var(--component-border, #eee);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  color: var(--text-color-secondary, #666);
}

.action-btn::after {
  border: none;
}

.action-btn.liked {
  color: var(--danger-color, #ff4757);
}

.action-btn.favorited {
  color: var(--brand-color, #00b3b3);
}

.bottom-bar-input-wrapper {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
}

.bottom-bar-input-wrapper-inner {
  flex: 1;
  background-color: var(--gray-color-1, #ffffff);
  border-radius: 40rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.bottom-bar-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  margin-left: 12rpx;
}
