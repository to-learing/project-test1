.topic-container {
  background-color: #f6f6f6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  /* 覆盖 TDesign 组件默认蓝色主题为青绿色（影响 FAB按钮、Tabs等） */
  --td-brand-color: var(--brand-color, #00b3b3);
  --td-brand-color-active: var(--brand-color-active, #146d63);
  --td-brand-color-light: var(--brand-color-light, #e6f7f5);
}

.header-area {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.search-box {
  padding: 16rpx 24rpx;
  background-color: #fff;
}

/* Tabs customization - 使用青绿色主题 */
.custom-tabs {
  --td-tab-item-active-color: var(--brand-color, #00b3b3);
  --td-tab-track-color: var(--brand-color, #00b3b3);
}

.topic-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.topic-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.card-hover {
  transform: scale(0.995);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.current-user-avatar {
  --td-avatar-bg-color: #ffffff;
}

.user-meta {
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.card-content {
  margin-bottom: 24rpx;
}

.media-preview {
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.media-preview.single-img {
  width: 100%;
}

.images-scroll {
  width: 100%;
  white-space: nowrap;
}

.scroll-images {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 16rpx;
}

.scroll-item {
  flex-shrink: 0;
}

.text-area .title {
  font-size: 34rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 12rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.summary {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  background-color: #f0f2f5;
  color: #555;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 32rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.tag-hash {
  color: var(--brand-color, #00b3b3); /* 青绿色主题色 */
  margin-right: 2rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between; /* Spread buttons */
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f9f9f9;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 10rpx;
  font-weight: 500;
}

.action-text.active {
  color: #ff4d4f;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: #bbb;
  font-size: 28rpx;
}

.empty-icon-wrapper {
  margin-bottom: 24rpx;
  opacity: 0.5;
}

/* 底部加载状态 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
}

.load-more .no-more {
  font-size: 24rpx;
  color: #999;
}

.footer-spacer {
  height: 160rpx; /* Space for FAB and bottom safe area */
}
