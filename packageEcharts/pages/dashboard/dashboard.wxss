/**
 * 数据大盘页面样式
 */


/** 
 * echarts 图表
 */
ec-canvas {
  width: 100%;
  height: 100%;
}

.dashboard-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* Tab切换栏 */
.tab-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  gap: 48rpx;
}

.tab-item {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--brand-color, #00b3b3);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--brand-color, #00b3b3);
  border-radius: 2rpx;
}

/* 分类筛选 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 32rpx;
  background: #fff;
  gap: 8rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
}

/* 大盘概览卡片 */
.overview-card {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #00b3b3 0%, #66c5be 100%);
  border-radius: 24rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 179, 179, 0.3);
}

.overview-header {
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 26rpx;
  opacity: 0.9;
}

.overview-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.overview-left {
  flex: 1;
}

.trend-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.trend-text {
  font-size: 56rpx;
  font-weight: 700;
}

.change-percent {
  font-size: 32rpx;
  font-weight: 600;
}

.change-percent.down {
  color: #ff6b6b;
}

.overview-right {
  width: 200rpx;
  height: 200rpx;
}

.ring-canvas {
  width: 100%;
  height: 100%;
}

/* 日期信息 */
.date-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 通用卡片样式 */
.stats-card,
.chart-card,
.suggestion-card,
.hot-category-card {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-link {
  font-size: 24rpx;
  color: var(--brand-color, #00b3b3);
}

/* 数据统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}

.stat-item {
  padding: 16rpx 0;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-change {
  font-size: 24rpx;
  font-weight: 500;
}

.stat-change.up {
  color: #07c160;
}

.stat-change.down {
  color: #ee0a24;
}

/* 图表容器 */
.chart-container {
  height: 400rpx;
  width: 100%;
}

.line-canvas {
  width: 100%;
  height: 100%;
}

/* 操作建议 */
.suggestion-item {
  display: flex;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.suggestion-item.risk {
  background: #fff5f5;
}

.suggestion-icon {
  width: 64rpx;
  height: 64rpx;
  background: var(--teal-color-1, #e6f7f5);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.suggestion-icon.risk-icon {
  background: #ffebeb;
}

.suggestion-content {
  flex: 1;
}

.suggestion-label {
  font-size: 26rpx;
  color: var(--brand-color, #00b3b3);
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.suggestion-label.risk-label {
  color: #ee0a24;
}

.suggestion-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.suggestion-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.suggestion-tag {
  margin-right: 0 !important;
}

.more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 40rpx;
  margin-top: 8rpx;
}

.more-text {
  font-size: 26rpx;
  color: var(--brand-color, #00b3b3);
}

/* 热门品类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #666;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.category-rank.rank-1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffb800 100%);
  color: #fff;
}

.category-rank.rank-2 {
  background: linear-gradient(135deg, #c0c0c0 0%, #a0a0a0 100%);
  color: #fff;
}

.category-rank.rank-3 {
  background: linear-gradient(135deg, #cd7f32 0%, #b87333 100%);
  color: #fff;
}

.category-image {
  width: 80rpx;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
}

.category-img {
  width: 100%;
  height: 100%;
}

.category-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.category-change {
  font-size: 28rpx;
  font-weight: 600;
}

.category-change.up {
  color: #07c160;
}

.category-change.down {
  color: #ee0a24;
}

/* 分类选择器弹窗 */
.category-picker {
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-content {
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.picker-item:active {
  background: #f8f8f8;
}

.picker-item.active {
  color: var(--brand-color, #00b3b3);
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}
