/* ========================================
   评论区分割线
   ======================================== */
.comment-divider {
  height: 3rpx;
  background-color: var(--component-stroke, #f5f5f5);
}

/* ========================================
   评论区
   ======================================== */
.comment-section {
  padding: 0 32rpx;
  background-color: var(--bg-color-container, #fff);
}

/* 评论数量头部 */
.comment-count-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.comment-count-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color-primary, #333);
}

.comment-sort {
  padding: 8rpx;
  color: var(--text-color-secondary, #999);
}

/* 评论输入区域 */
.comment-input-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
}

.current-user-avatar {
  --td-avatar-bg-color: #ffffff;
}

.comment-input-placeholder {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--bg-secondary, #f5f5f5);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--text-color-placeholder, #bbb);
}

.input-actions {
  display: flex;
  gap: 20rpx;
}

/* ========================================
   评论列表
   ======================================== */
.comment-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.comment-nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color-primary, #333);
}

.comment-text {
  font-size: 30rpx;
  color: var(--text-color-primary, #333);
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-word;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 24rpx;
  color: var(--text-color-placeholder, #bbb);
}

.comment-time,
.comment-location {
  color: var(--text-color-placeholder, #bbb);
}

.comment-action-reply,
.comment-action-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: var(--text-color-secondary, #999);
}

.comment-action-like {
  margin-left: auto;
  margin-right: 5%;
}

.comment-action-like.liked {
  color: var(--danger-color, #ff4757);
}

/* ========================================
   子评论区域
   ======================================== */
.child-comments {
  margin-top: 30rpx;
}

.child-comment-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.child-comment-item:last-child {
  margin-bottom: 0;
}

.child-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: var(--bg-color-container, #fff);
}

.child-content {
  flex: 1;
  min-width: 0;
}

.child-user-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.child-nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color-primary, #333);
}

.child-text {
  font-size: 30rpx;
  color: var(--text-color-primary, #333);
  line-height: 1.5;
  margin-bottom: 12rpx;
  word-break: break-word;
}

.reply-target {
  color: var(--text-color-placeholder, #b3b3b6ff);
  display: inline;
  white-space: nowrap;
  margin: 0 6rpx;
}

.child-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-color-placeholder, #bbb);
}

.child-action-reply,
.child-action-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--text-color-secondary, #999);
}

.child-action-like {
  margin-left: auto;
  margin-right: 5%;
}

.child-action-like.liked {
  color: var(--danger-color, #ff4757);
}

/* 展开/收起回复 */
.expand-replies {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  font-size: 26rpx;
  color: var(--brand-color, #00b3b3);
}

/* ========================================
   加载更多
   ======================================== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.load-more-btn {
  color: var(--brand-color, #00b3b3);
  font-size: 28rpx;
}

.no-more {
  color: var(--text-color-placeholder, #bbb);
  font-size: 26rpx;
}

/* ========================================
   评论输入遮罩层
   ======================================== */
.comment-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 998;
}

/* ========================================
   评论输入区域（固定定位）
   ======================================== */
.comment-input-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background-color: var(--bg-color-container, #fff);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: bottom 0.15s ease-out;
}

.comment-input-popup {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color-primary, #333);
}

.input-close {
  padding: 8rpx;
}

.input-wrapper {
  margin-bottom: 20rpx;
}

.comment-textarea {
  width: 100%;
  min-height: 120rpx;
  max-height: 240rpx;
  padding: 24rpx;
  background-color: var(--bg-secondary, #f5f5f5);
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.send-btn {
  min-width: 160rpx;
}

.popup-tools {
  display: flex;
  gap: 32rpx;
}

/* ========================================
   操作菜单样式
   ======================================== */
.action-sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 998;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background-color: var(--bg-secondary, #f5f5f5);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  animation: slideUp 0.3s ease-out;
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.action-sheet-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  background-color: var(--bg-color-container, #fff);
  border-bottom: 1rpx solid var(--component-stroke, #eee);
}

.action-sheet-title {
  font-size: 26rpx;
  color: var(--text-color-placeholder, #999);
}

.action-sheet-list {
  background-color: var(--bg-color-container, #fff);
  margin-top: 16rpx;
}

.action-sheet-item {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--component-stroke, #eee);
  background-color: var(--bg-color-container, #fff);
}

.action-sheet-item:last-child {
  border-bottom: none;
}

.action-sheet-item:active {
  background-color: var(--bg-secondary, #f5f5f5);
}

.action-sheet-item.danger .action-sheet-label {
  color: #ff4d4f;
}

.action-sheet-label {
  font-size: 32rpx;
  color: var(--text-color-primary, #333);
}

.action-sheet-cancel {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx;
  margin-top: 16rpx;
  background-color: var(--bg-color-container, #fff);
}

.action-sheet-cancel:active {
  background-color: var(--bg-secondary, #f5f5f5);
}

.action-sheet-cancel text {
  font-size: 32rpx;
  color: var(--text-color-primary, #333);
}
